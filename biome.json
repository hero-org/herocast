{
  "$schema": "https://biomejs.dev/schemas/2.3.12/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "files": {
    "includes": [
      "**/*.ts",
      "**/*.tsx",
      "**/*.js",
      "**/*.jsx",
      "**/*.json",
      "**/*.md",
      "!.context",
      "!.next",
      "!supabase/functions",
      "!src/common/types/database.types.ts"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedVariables": "off",
        "noUnusedImports": "warn",
        "noUnusedFunctionParameters": "off",
        "useExhaustiveDependencies": "off",
        "useHookAtTopLevel": "warn",
        "useParseIntRadix": "off"
      },
      "suspicious": {
        "noExplicitAny": "off",
        "noArrayIndexKey": "off",
        "noAssignInExpressions": "off",
        "noConfusingVoidType": "off",
        "noDoubleEquals": "off",
        "noGlobalIsNan": "off",
        "noImplicitAnyLet": "off",
        "noDuplicateObjectKeys": "off",
        "noDuplicateClassMembers": "off",
        "noDocumentCookie": "off",
        "useIterableCallbackReturn": "off"
      },
      "a11y": {
        "noSvgWithoutTitle": "off",
        "noRedundantRoles": "off",
        "noAutofocus": "off",
        "noStaticElementInteractions": "off",
        "noLabelWithoutControl": "off",
        "useKeyWithClickEvents": "off",
        "useValidAnchor": "off",
        "useButtonType": "off",
        "useSemanticElements": "off",
        "useHtmlLang": "off",
        "useAltText": "off"
      },
      "complexity": {
        "noForEach": "off",
        "noUselessFragments": "off",
        "useOptionalChain": "off",
        "noUselessSwitchCase": "off",
        "useLiteralKeys": "off"
      },
      "style": {
        "noNonNullAssertion": "off",
        "noParameterAssign": "off",
        "useTemplate": "off",
        "useNodejsImportProtocol": "off"
      },
      "performance": {
        "noAccumulatingSpread": "off",
        "noImgElement": "off"
      },
      "security": {
        "noDangerouslySetInnerHtml": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "es5",
      "semicolons": "always"
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": [
        "src/components/ui/**/*.ts",
        "src/components/ui/**/*.tsx",
        "!src/components/ui/sidebar.tsx",
        "!src/components/ui/toaster.tsx"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "warn",
              "options": {
                "patterns": [
                  {
                    "group": ["@/stores", "@/stores/**"],
                    "message": "UI primitives (src/components/ui) must not import stores. Lift state to src/common/components."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/stores/**/*.ts", "src/stores/**/*.tsx"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "warn",
              "options": {
                "patterns": [
                  {
                    "group": ["@/components/**", "@/common/components/**", "next/*"],
                    "message": "Stores must not import UI components or Next.js internals."
                  }
                ]
              }
            }
          }
        }
      }
    }
  ]
}

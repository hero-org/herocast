# Client build-time config, inlined by Vite from import.meta.env.VITE_*.
# Copy to `.env.local` (gitignored). These are NOT secrets and are NOT set via
# `wrangler secret put` — they are baked into the client bundle at build time.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# PostHog product analytics — client-only, inlined by Vite from import.meta.env.
# No key ⇒ analytics is a no-op (loadPosthog() returns undefined; forkable).
# VITE_POSTHOG_HOST is optional and defaults to PostHog Cloud US.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=

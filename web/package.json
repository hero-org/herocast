{
  "name": "herocast-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "herocast on TanStack Start (SSR) + Cloudflare Workers — Track B migration of hero-org/herocast#754. Phase 1 Foundation.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "serve": "wrangler dev -c dist/server/wrangler.json --port 8799",
    "deploy": "vite build && wrangler deploy -c dist/server/wrangler.json",
    "deploy:dry-run": "vite build && wrangler deploy -c dist/server/wrangler.json --dry-run",
    "cf-typegen": "wrangler types",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.1.1",
    "@fontsource-variable/jetbrains-mono": "^5.1.1",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.91.1",
    "@tanstack/react-query": "^5.90.11",
    "@tanstack/react-router": "^1.168.0",
    "@tanstack/react-start": "^1.168.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.411.0",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.0.0",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/react-query-devtools": "^5.91.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.0.0"
  }
}
